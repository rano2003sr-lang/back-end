# MongoDB Atlas - استبدل بالقيم الفعلية
MONGODB_URI=mongodb://username:password@host/database

# Brevo - API key من لوحة Brevo
BREVO_API_KEY=your-brevo-api-key
BREVO_FROM_EMAIL=your-email@example.com

# JWT
JWT_SECRET=your-super-secret-jwt-key

NODE_ENV=development

# LiveKit — للصوت المباشر (مجاني عند الاستضافة الذاتية أو أرخص من Agora)
# من cloud.livekit.io أو استضافة ذاتية
LIVEKIT_WS_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret
